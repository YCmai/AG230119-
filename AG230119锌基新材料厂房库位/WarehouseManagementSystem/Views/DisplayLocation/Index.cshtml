});

function addCollapseAllButtons() {
    // 创建按钮容器
    const buttonContainer = document.createElement('div');
    buttonContainer.className = 'collapse-buttons mb-3 text-end';
    
    // 创建展开全部按钮
    // const expandAllBtn = document.createElement('button');
    // expandAllBtn.className = 'btn btn-outline-primary btn-sm me-2';
    // expandAllBtn.innerHTML = '<i class="fas fa-expand-alt"></i> 展开全部';
    // expandAllBtn.onclick = expandAllGroups;
    
    // 创建折叠全部按钮
    // const collapseAllBtn = document.createElement('button');
    // collapseAllBtn.className = 'btn btn-outline-secondary btn-sm';
    // collapseAllBtn.innerHTML = '<i class="fas fa-compress-alt"></i> 折叠全部';
    // collapseAllBtn.onclick = collapseAllGroups;
    
    // 添加按钮到容器
    buttonContainer.appendChild(expandAllBtn);
    buttonContainer.appendChild(collapseAllBtn);
    
    // 将按钮容器添加到groups-wrapper之前
    const groupsWrapper = document.querySelector('.groups-wrapper');
    groupsWrapper.parentNode.insertBefore(buttonContainer, groupsWrapper);
}

function expandAllGroups() {
    document.querySelectorAll('.locations-container.collapse').forEach(container => {
        bootstrap.Collapse.getInstance(container)?.show();
        const header = container.previousElementSibling;
        const icon = header.querySelector('.group-toggle-icon');
        if (icon) {
            icon.classList.add('fa-chevron-down');
            icon.classList.remove('fa-chevron-right');
        }
    });
}

function collapseAllGroups() {
    document.querySelectorAll('.locations-container.collapse.show').forEach(container => {
        bootstrap.Collapse.getInstance(container)?.hide();
        const header = container.previousElementSibling;
        const icon = header.querySelector('.group-toggle-icon');
        if (icon) {
            icon.classList.remove('fa-chevron-down');
            icon.classList.add('fa-chevron-right');
        }
    });
}

function showLocationDetails(id, nodeRemark, materialCode, palletID, entryDate, weight, quantity, group, liftingHeight, lock) {
    currentLocationId = id;
    
    // 更新模态框内容
    document.getElementById('nodeRemark').textContent = nodeRemark;
    document.getElementById('locationStatus').textContent = materialCode ? '已占用' : '空闲';
    document.getElementById('materialCode').textContent = materialCode || '无';
    document.getElementById('palletID').textContent = palletID || '无';
    document.getElementById('entryDate').textContent = entryDate || '无';
    document.getElementById('weight').textContent = weight || '0';
    document.getElementById('quantity').textContent = quantity || '0';
    document.getElementById('liftingHeight').textContent = liftingHeight || '0';
    
    // 更新锁定状态和按钮文本
    const isLocked = lock === 'True';
    document.getElementById('lockStatus').textContent = isLocked ? '已锁定' : '未锁定';
    
    // 更新锁定按钮状态和文本
    const lockButton = document.getElementById('lockButton');
    const lockButtonText = document.getElementById('lockButtonText');
    if (isLocked) {
        lockButton.classList.remove('btn-warning');
        lockButton.classList.add('btn-success');
        lockButtonText.textContent = '解锁';
        lockButton.querySelector('i').classList.remove('fa-lock');
        lockButton.querySelector('i').classList.add('fa-unlock');
    } else {
        lockButton.classList.remove('btn-success');
        lockButton.classList.add('btn-warning');
        lockButtonText.textContent = '锁定';
        lockButton.querySelector('i').classList.remove('fa-unlock');
        lockButton.querySelector('i').classList.add('fa-lock');
    }
    
    // 显示模态框
    locationModal.show();
}

function createNewLocation() {
    window.location.href = '/DisplayLocation/CreateEdit';
}

function editLocation() {
    if (!currentLocationId) return;
    window.location.href = `/DisplayLocation/CreateEdit/${currentLocationId}`;
}

async function handleLocationAction(actionType) {
    if (!currentLocationId) return;
    
    let confirmMessage = '';
    switch (actionType) {
        case 1:
            confirmMessage = '确定要删除此储位吗？';
            break;
        case 3:
            confirmMessage = '确定要清空此储位吗？';
            break;
        case 4:
            confirmMessage = '确定要重置此储位吗？';
            break;
        case 2:
            const isLocked = document.getElementById('lockStatus').textContent === '已锁定';
            confirmMessage = isLocked ? '确定要解锁此储位吗？' : '确定要锁定此储位吗？';
            break;
    }
    
    if (confirmMessage && !confirm(confirmMessage + '此操作不可恢复！')) {
        return;
    }
    
    try {
        const params = new URLSearchParams({
            type: actionType.toString()
        });
        
        const response = await fetch(`/DisplayLocation/DeleteConfirmed/${currentLocationId}?${params}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        });
        
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const result = await response.json();
        
        if (result.success) {
            if (actionType === 1) {
                locationModal.hide();
            }
            // 创建一个 Promise 来等待 toast 显示完成
            await new Promise(resolve => {
                const toast = showToast('success', result.message);
                toast.addEventListener('shown.bs.toast', () => {
                    setTimeout(resolve, 800); // 等待 toast 显示 800ms
                });
            });
            window.location.reload();
        } else {
            showToast('error', result.message || '操作失败');
        }
    } catch (error) {
        console.error('操作失败:', error);
        showToast('error', '操作失败，请重试');
    }
}

function filterLocations(searchText) {
    try {
        // 转换为小写以进行不区分大小写的搜索
        searchText = searchText.toLowerCase();

        // 获取所有储位元素
        const locationBoxes = document.querySelectorAll('.location-box');

        locationBoxes.forEach(box => {
            // 获取储位编号
            const locationNumber = box.getAttribute('data-location');

            // 如果搜索文本为空，显示所有储位
            if (!searchText) {
                box.style.display = '';
                return;
            }

            // 检查储位编号是否包含搜索文本
            if (locationNumber && locationNumber.toLowerCase().includes(searchText)) {
                box.style.display = '';
            } else {
                box.style.display = 'none';
            }
        });

        // 处理分组的显示/隐藏
        const groups = document.querySelectorAll('.location-group');
        groups.forEach(group => {
            // 检查该分组是否有任何可见的储位
            const hasVisibleLocations = Array.from(group.querySelectorAll('.location-box'))
                .some(box => box.style.display !== 'none');

            // 根据是否有可见储位来显示/隐藏整个分组
            group.style.display = hasVisibleLocations ? '' : 'none';
        });

    } catch (error) {
        console.error('搜索储位时发生错误:', error);
    }
}

function showToast(type, message) {
    let toastContainer = document.getElementById('toastContainer');
    
    if (!toastContainer) {
        toastContainer = document.createElement('div');
        toastContainer.id = 'toastContainer';
        toastContainer.style.position = 'fixed';
        toastContainer.style.top = '20px';
        toastContainer.style.right = '20px';
        toastContainer.style.zIndex = '9999';
        document.body.appendChild(toastContainer);
    }
    
    const toast = document.createElement('div');
    toast.className = `toast align-items-center text-white bg-${type === 'success' ? 'success' : 'danger'} border-0`;
    toast.setAttribute('role', 'alert');
    toast.setAttribute('aria-live', 'assertive');
    toast.setAttribute('aria-atomic', 'true');
    
    toast.innerHTML = `
        <div class="d-flex">
            <div class="toast-body">
                ${message}
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    `;
    
    toastContainer.appendChild(toast);
    const bsToast = new bootstrap.Toast(toast);
    bsToast.show();
    
    toast.addEventListener('hidden.bs.toast', () => {
        toast.remove();
    });

    return toast;
}

