<script>
let currentLocationId = null;
let locationModal = null;
let locationSelectorModal;

document.addEventListener('DOMContentLoaded', function() {
    locationModal = new bootstrap.Modal(document.getElementById('locationDetailsModal'));
    locationSelectorModal = new bootstrap.Modal(document.getElementById('locationSelectorModal'));
    
