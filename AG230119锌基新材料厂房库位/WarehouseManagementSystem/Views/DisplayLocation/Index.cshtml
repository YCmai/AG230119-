            const hasVisibleLocations = Array.from(group.querySelectorAll('.location-box'))
                .some(box => box.style.display !== 'none');

            // 根据是否有可见储位来显示/隐藏整个分组
            group.style.display = hasVisibleLocations ? '' : 'none';
        });

    } catch (error) {
        console.error('搜索储位时发生错误:', error);
    }
}

function batchClearMaterialCodeByGroup() {
    var group = $('#batchOperationGroup').val();
    if (!group) {
        alert('请选择要操作的分组');
        return;
    }
    
    if (!confirm(`确定要清空 ${group} 内的所有物料编号吗？此操作不可恢复！`)) {
        return;
    }
    
    $.ajax({
        url: '/DisplayLocation/BatchClearMaterialCodeByGroup',
        type: 'POST',
        data: { group: group },
        success: function(result) {
            if (result.success) {
                alert(`${result.message}`);
                location.reload();
            } else {
                alert(`操作失败: ${result.message}`);
            }
        },
        error: function() {
            alert('操作请求失败，请检查网络连接');
        }
    });
}
</script>

